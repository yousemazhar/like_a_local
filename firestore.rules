rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Server-only fields on the user doc.
    function noUserServerFieldChanges() {
      let serverKeys = ['premium', 'premiumUpdatedAt',
                        'stripeCustomerId', 'lastPaymentIntentId',
                        'entitlements', 'role', 'superUserScore',
                        'superUserStats', 'superUserBecameAt',
                        'superUserScoreUpdatedAt'];
      return !request.resource.data.diff(resource.data)
          .affectedKeys().hasAny(serverKeys);
    }

    function noPlaceServerFields() {
      return !request.resource.data.keys()
          .hasAny(['ownerIsSuper', 'ownerSuperScore', 'ratingAvg',
                   'ratingCount', 'saveCount']);
    }

    function noPlaceServerFieldChanges() {
      return !request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasAny(['ownerIsSuper', 'ownerSuperScore', 'ratingAvg',
                   'ratingCount', 'saveCount']);
    }

    match /users/{uid} {
      // Any signed-in user can read a profile (displayName, photoUrl,
      // role). Sensitive write-only fields are protected separately by
      // noServerFieldChanges() below.
      allow read: if isSignedIn();
      allow create: if isOwner(uid)
        && !request.resource.data.keys().hasAny(
             ['premium', 'premiumUpdatedAt', 'stripeCustomerId',
              'lastPaymentIntentId', 'entitlements', 'superUserScore',
              'superUserStats', 'superUserBecameAt',
              'superUserScoreUpdatedAt'])
        && (!request.resource.data.keys().hasAny(['role'])
            || request.resource.data.role == 'user');
      allow update: if isOwner(uid) && noUserServerFieldChanges();
      allow delete: if false;
    }

    // Places: any signed-in user reads; only the owner writes their own.
    match /places/{placeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && noPlaceServerFields();
      allow update: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid
        && noPlaceServerFieldChanges();
      allow delete: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;

      match /media/{mediaId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn()
          && get(/databases/$(database)/documents/places/$(placeId))
               .data.ownerUid == request.auth.uid;
      }

      match /reviews/{reviewId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if isSignedIn()
          && resource.data.authorUid == request.auth.uid;
      }
    }

    // Saves: owner-only (per-user collection).
    match /saves/{uid}/{document=**} {
      allow read, write: if isOwner(uid);
    }

    // Chats: only members can read/write the thread + its messages.
    match /chats/{threadId} {
      // Allow a single-doc get when the doc doesn't exist yet so the
      // client can probe before creating it. Existing-doc reads still
      // require membership.
      allow get: if isSignedIn()
        && (resource == null || request.auth.uid in resource.data.members);
      allow list: if isSignedIn()
        && request.auth.uid in resource.data.members;
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.members;
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.members;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in
             get(/databases/$(database)/documents/chats/$(threadId)).data.members;
        allow create: if isSignedIn()
          && request.resource.data.senderUid == request.auth.uid
          && request.auth.uid in
             get(/databases/$(database)/documents/chats/$(threadId)).data.members;
        allow update, delete: if false;
      }
    }

    // Notifications: owner reads, server (Admin SDK) writes; owner can flip read flag.
    // Owner can also create proximity notifications from the client (ReminderLocationService).
    match /notifications/{uid}/items/{itemId} {
      allow read: if isOwner(uid);
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['read']);
      allow create: if isOwner(uid)
        && request.resource.data.type == 'pinNear';
      allow delete: if false;
    }

    // Rankings: owner-read, server-write only.
    match /rankings/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Reminders: owner-only.
    match /reminders/{uid}/{document=**} {
      allow read, write: if isOwner(uid);
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
