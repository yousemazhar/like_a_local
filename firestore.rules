rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Fields that only the server (Cloud Functions / Admin SDK) may write.
    // Client-initiated writes cannot add, change, or remove these keys.
    function noServerFieldChanges() {
      let serverKeys = ['premium', 'premiumUpdatedAt',
                        'stripeCustomerId', 'lastPaymentIntentId',
                        'entitlements'];
      return !request.resource.data.diff(resource.data)
          .affectedKeys().hasAny(serverKeys);
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && !request.resource.data.keys().hasAny(
             ['premium', 'premiumUpdatedAt', 'stripeCustomerId',
              'lastPaymentIntentId', 'entitlements']);
      allow update: if isOwner(uid) && noServerFieldChanges();
      allow delete: if false;
    }

    // Deny everything else by default. Add rules here as features land.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
